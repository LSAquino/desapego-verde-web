# Frontend (Vite)
# Em desenvolvimento local, pode deixar vazio para usar o proxy /api do Vite.
VITE_API_URL=

# Exemplo para produção (Vercel):
# VITE_API_URL=https://seu-backend.exemplo.com

# Backend (Render)
# URL de conexão do banco
DATABASE_URL=
DIRECT_URL=

# JWT usado no login
JWT_SECRET=

# WebAuthn/Passkeys em produção
# RP ID: apenas host, sem protocolo
# Exemplo: desapego-verde-web.onrender.com
WEBAUTHN_RP_ID=

# Origin completo do frontend/PWA
# Exemplo: https://desapego-verde-web.onrender.com
WEBAUTHN_ORIGIN=

# Lista de origens permitidas no CORS separadas por vírgula
# Exemplo: https://desapego-verde-web.onrender.com,https://seu-frontend.vercel.app
CORS_ORIGINS=
